# Local dev (split Vite + API)
VITE_API_URL=http://localhost:5000/api
VITE_SERVER_URL=http://localhost:5000

# Docker / same-origin production build: use /api and omit VITE_SERVER_URL so the app uses the page origin.

# Optional override for promotion image URL (JPEG/PNG, min 500×500px)
# VITE_DEFAULT_PROMOTION_IMAGE_URL=https://example.com/promo-500.png
